
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LabTrack Security Rules
     * 
     * CORE PHILOSOPHY:
     * Standardized security model that enforces ownership and explicit role-based access.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user is an administrator.
     * Uses the optimized /admin_roles collection for verification.
     */
    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    /** 
     * Checks if the authenticated user is one of the hardcoded bootstrap administrators.
     */
    function isBootstrapAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'venicemarizene.linga@neu.edu.ph' || 
        request.auth.token.email == 'jcesperanza@neu.edu.ph'
      );
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile data.
     */
    match /user_profiles/{userId} {
      // Use standard read rules; Firestore will enforce ownership as a filter for list queries
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Lab room definitions.
     */
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Usage logs for laboratory sessions.
     */
    match /room_logs/{logId} {
      // Standard read rule; requires a filter matching professorId for non-admins
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.professorId == request.auth.uid)
      );
      allow create: if isSignedIn() && request.resource.data.professorId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource != null && resource.data.professorId == request.auth.uid && request.resource.data.professorId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    /**
     * @description System-level collection for role-based access control.
     */
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isBootstrapAdmin() && request.auth.uid == adminUid;
      allow update, delete: if isAdmin();
    }
  }
}
