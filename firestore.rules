rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LabTrack Security Rules
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid security model designed for a university computer laboratory 
     * tracking system. It prioritizes Authorization Independence by using a dedicated collection 
     * for administrative roles, ensuring that role-based checks are performant and atomic.
     * 
     * DATA STRUCTURE:
     * - /user_profiles/{userId}: User-specific data protected by path-based ownership.
     * - /rooms/{roomId}: Laboratory room definitions, globally readable but admin-modifiable.
     * - /room_logs/{logId}: Usage logs secured via denormalized ownership (professorId).
     * - /admin_roles/{adminUid}: A system collection used for high-performance admin verification.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Admin status is verified by the existence of a document in 
     *    /admin_roles, avoiding costly get() calls on user profiles during rule evaluation.
     * 2. Denormalization for Performance: Room logs contain a 'professorId' field to allow 
     *    direct ownership checks without parent-document lookups.
     * 3. Public Room Listing: Room information (M101-M111) is publicly readable to allow 
     *    authenticated and unauthenticated users to view lab availability.
     * 4. Relational Integrity: On creation, documents are required to have internal IDs 
     *    matching their paths (e.g., UserProfile.id == userId).
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user is an administrator.
     * Uses the optimized /admin_roles collection for verification.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies that a field in the existing document matches the user's UID. */
    function isDocOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile data. Users manage their own; admins manage all.
     * @path /user_profiles/{userId}
     * @allow get (owner or admin), create (self-registration), update (owner or admin).
     * @deny delete (non-admins), update (modifying the profile ID).
     * @principle Path-based ownership and relational integrity validation.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Lab room definitions. Read-only for most; writable by admins.
     * @path /rooms/{roomId}
     * @allow get, list (public), create/update/delete (admins).
     * @deny write (professors or unauthenticated users).
     * @principle Public read-access with restricted administrative writes.
     */
    match /rooms/{roomId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Usage logs for laboratory sessions.
     * @path /room_logs/{logId}
     * @allow create (signed-in user setting self as professor), update (owner or admin), list (owner or admin).
     * @deny create (setting another user as professor), delete (non-admins).
     *  NOTE: List rule requires queries to filter by professorId for non-admins, but this cannot be enforced directly in rules
     *  without potentially complex `get` or `list` checks that could affect performance. The `request.query.limit` check
     *  is a basic safeguard, but backend queries must correctly apply the `professorId` filter.
     * @principle Denormalized ownership verification for scalable query authorization.
     */
    match /room_logs/{logId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.professorId == request.auth.uid);
      // For list, non-admins should only see their own logs. Backend queries must enforce filtering by professorId.
      // The rules here provide a basic limit check and rely on isAdmin for full access.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn() && request.resource.data.professorId == request.auth.uid;
      allow update: if (isAdmin() || isDocOwner('professorId')) && resource != null && request.resource.data.professorId == resource.data.professorId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description System-level collection for role-based access control.
     * @path /admin_roles/{adminUid}
     * @allow get (any signed-in user for status check), list (admins).
     * @deny create, update, delete (all users via API; managed via backend/console).
     * @principle Authorization Independence via existence-based role checking.
     */
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}