
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU LabTrack Security Rules
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid security model designed for a university computer laboratory 
     * tracking system. It prioritizes Authorization Independence by using a dedicated collection 
     * for administrative roles.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user is an administrator.
     * Uses the optimized /admin_roles collection for verification.
     */
    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
      );
    }

    /** 
     * Checks if the authenticated user is one of the hardcoded bootstrap administrators.
     */
    function isBootstrapAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'venicemarizene.linga@neu.edu.ph' || 
        request.auth.token.email == 'jcesperanza@neu.edu.ph'
      );
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile data. Users manage their own; admins manage all.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Lab room definitions. Read-only for most; writable by admins.
     */
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Usage logs for laboratory sessions.
     * Prioritize ownership check to allow professors to query their own sessions.
     */
    match /room_logs/{logId} {
      allow get, list: if isSignedIn() && (
        isAdmin() || 
        resource.data.professorId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.professorId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource != null && resource.data.professorId == request.auth.uid && request.resource.data.professorId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    /**
     * @description System-level collection for role-based access control.
     */
    match /admin_roles/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isBootstrapAdmin() && request.auth.uid == adminUid;
      allow update, delete: if isAdmin();
    }
  }
}
